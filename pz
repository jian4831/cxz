        echo "  2) 启用并启动服务（开机自启）"
        echo "  3) 停止并禁用服务"
        echo "  4) 查看服务运行状态（健康检查）"
        echo "  5) 删除 systemd 服务文件"
        echo ""
        echo "【其他功能】"
        echo "  6) 更新/安装游戏"
        echo "  7) 修改服务器配置文件"
        echo "  8) 删除存档并重启服务器"
        echo "  9) 前台运行服务器（调试模式）"
        echo " 10) 自动修复与定时任务管理"
        echo " 11) 实时查看服务器日志"
        echo " 12) 设置游戏中文语言（修改 ProjectZomboid64.json）"
        echo ""
        echo "  0) 退出脚本"
        echo "=========================================="
        read -p "请输入选项数字: " choice

        case $choice in
            1) create_service ;;
            2) enable_service ;;
            3) disable_service ;;
            4) view_status ;;
            5) delete_service ;;
            6) choose_login; update_game ;;
            7) modify_config ;;
            8) delete_map ;;
            9) run_foreground ;;
            10) submenu_autoheal ;;
            11) view_logs ;;
            12) set_game_language ;;
            0) info "退出脚本。"; exit 0 ;;
            *) error "无效选项。" ;;
        esac
    done
}

# ----------------------------- 入口 ------------------------------------------
main() {
    detect_distro
    check_user
    check_environment

    info "PZ 服务器管理脚本 v6.6 启动"

    if [ ! -d "$GAME_DIR" ] || [ ! -f "$GAME_DIR/start-server.sh" ]; then
        warn "游戏服务端未安装，开始初始化..."
        init_steamcmd
        choose_login
        update_game
    else
        info "检测到游戏已安装。"
    fi

    first_run_wizard
    main_menu
}

# ----------------------------- 命令行参数 ------------------------------------
if [ "$1" = "--check" ] || [ "$1" = "-c" ]; then
    detect_distro
    check_user
    internal_status_check
    status=$?
    if [ $status -eq 1 ] || [ $status -eq 2 ] || [ $status -eq 3 ]; then
        echo "[$(date)] 服务器状态异常，尝试自动修复..."
        systemctl stop "$SERVICE_NAME" 2>/dev/null || true
        sleep 2
        systemctl start "$SERVICE_NAME"
    elif [ $status -eq 4 ]; then
        echo "[$(date)] 服务器运行正常（但不受 systemd 管理），跳过修复。"
    else
        echo "[$(date)] 服务器运行正常。"
    fi
    exit 0
fi

main "$@"
