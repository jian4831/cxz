run_foreground() {
    step "前台运行服务器（调试模式）"
    
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        warn "后台 systemd 服务正在运行，前台运行可能导致端口冲突。"
        read -p "是否停止后台服务？(y/N): " stop_confirm
        if [[ "$stop_confirm" =~ ^[Yy]$ ]]; then
            systemctl stop "$SERVICE_NAME"
            info "后台服务已停止。"
        else
            info "已取消前台运行。"
            return
