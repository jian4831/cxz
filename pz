# ----------------------------- 定时任务管理 ----------------------------------
enable_cron() {
    step "启用定时自动修复（每5分钟）"
    local script_path=$(readlink -f "$0")
    local CRON_CMD="*/5 * * * * $script_path --check >> /var/log/pz_autoheal.log 2>&1 $CRON_MARKER"
    
    if crontab -l 2>/dev/null | grep -q "$CRON_MARKER"; then
        warn "定时任务已存在，无需重复添加。"
    else
        (crontab -l 2>/dev/null; echo "$CRON_CMD") | crontab -
        info "定时任务已添加。每5分钟自动检测并修复服务器状态。"
        info "日志文件: /var/log/pz_autoheal.log"
        echo "建议配置 logrotate 管理该日志，避免无限增长。"
    fi
    read -p "按回车键继续..."
}

disable_cron() {
    step "禁用定时自动修复"
    if crontab -l 2>/dev/null | grep -q "$CRON_MARKER"; then
        crontab -l 2>/dev/null | grep -v "$CRON_MARKER" | crontab -
        info "定时任务已移除。"
    else
        warn "未找到定时任务，无需操作。"
    fi
    read -p "按回车键继续..."
}

manual_heal() {
    step "检测服务器状态并自动修复"
    internal_status_check
    local status=$?
    
    case $status in
        0)
            info "✅ 服务器运行正常，无需操作。"
            ;;
        1|2|3)
            warn "服务器状态异常，正在尝试重启服务..."
            systemctl stop "$SERVICE_NAME" 2>/dev/null || true
            sleep 2
            systemctl start "$SERVICE_NAME"
            info "服务已重启。"
            ;;
        4)
            warn "服务器正在运行但不受 systemd 管理，将跳过修复。"
            info "若需要纳入 systemd 管理，请先停止当前进程再启用服务。"
            ;;
    esac

    if [ $status -ne 0 ] && [ $status -ne 4 ]; then
        sleep 5
        internal_status_check
        if [ $? -eq 0 ]; then
            info "✅ 服务器已成功启动并正常运行。"
        else
            error "❌ 服务器未能正常启动，请检查日志。"
        fi
    fi
    echo ""
    read -p "按回车键继续..."
}

submenu_autoheal() {
    while true; do
        echo ""
        echo "=========================================="
        echo "         自动修复与定时任务管理           "
        echo "=========================================="
        echo "  1) 手动执行一次检测并修复"
        echo "  2) 启用定时自动修复（每5分钟）"
        echo "  3) 禁用定时自动修复"
        echo "  4) 返回主菜单"
        echo "=========================================="
        read -p "请输入选项数字: " sub_choice

        case $sub_choice in
            1) manual_heal ;;
            2) enable_cron ;;
            3) disable_cron ;;
            4) return ;;
            *) error "无效选项，请重新输入。" ;;
        esac
    done
}

# ----------------------------- 删除存档 --------------------------------------
delete_map() {
    step "删除存档"
    local save_base="$SAVE_DIR"
    
    if [ ! -d "$save_base" ]; then
        warn "存档目录不存在: $save_base"
        return
    fi

    local maps=()
    while IFS= read -r dir; do
        maps+=("$dir")
    done < <(find "$save_base" -maxdepth 1 -type d ! -path "$save_base" -printf "%f\n" 2>/dev/null | sort)

    if [ ${#maps[@]} -eq 0 ]; then
        warn "没有找到任何存档。"
        return
    fi

    echo "现有存档列表："
    for i in "${!maps[@]}"; do
        printf "  %2d) %s\n" $((i+1)) "${maps[$i]}"
    done
    echo "   0) 取消"

    local choice
    while true; do
        read -p "请输入要删除的存档编号: " choice
        if [[ "$choice" == "0" ]]; then
            info "取消删除。"
            return
        elif [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le ${#maps[@]} ]; then
            break
        else
            error "无效编号，请重新输入。"
        fi
    done

    local selected="${maps[$((choice-1))]}"
    local target="$save_base/$selected"

    if [[ "$target" != "$save_base"/* ]]; then
        error "路径校验失败，中止删除。"
        return
    fi

    echo ""
    echo "即将删除存档: $selected"
    echo "完整路径: $target"
    read -p "确认删除并重启服务器？(y/N): " confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        info "取消删除。"
        return
    fi

    local was_running=false
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        was_running=true
        info "检测到后台服务正在运行，将先停止服务..."
        systemctl stop "$SERVICE_NAME"
        sleep 3
    else
        info "服务器当前未运行。"
    fi

    rm -rf "$target"
    info "存档 '$selected' 已删除。"

    if [ "$was_running" = true ]; then
        info "等待 15 秒后重新启动服务器..."
        for i in {15..1}; do
            printf "\r  剩余 %2d 秒..." "$i"
            sleep 1
        done
        printf "\r\033[K"
        systemctl start "$SERVICE_NAME"
        
        local game_port=$(get_config_port)
        info "服务器已启动，等待端口 ${game_port} 监听（最多 60 秒）..."

        local count=0
        while [ $count -lt 60 ]; do
            if ss -tlnp 2>/dev/null | grep -q ":$game_port " || netstat -tlnp 2>/dev/null | grep -q ":$game_port "; then
                info "✅ 服务器端口 ${game_port} 已监听，启动成功！"
                break
            fi
            sleep 2
            count=$((count + 2))
        done
        if [ $count -ge 60 ]; then
            error "❌ 服务器启动超时，端口 ${game_port} 未监听。请检查日志。"
        fi
        deep_status_check
    else
        info "服务器未重新启动（之前未运行）。"
    fi

    read -p "按回车键返回主菜单..."
}

